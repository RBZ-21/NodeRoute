{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NodeRoute",
  "version": "0.1.0",
  "identifier": "com.noderoute.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --mode tauri",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build -- --mode tauri",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 720,
        "height": 405,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true
      },
      {
        "label": "main",
        "title": "NodeRoute",
        "url": "https://noderoutesystems.com/login",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "publisher": "NodeRoute LLC",
    "copyright": "Copyright \u00a9 2026 NodeRoute LLC",
    "category": "Business",
    "shortDescription": "Smart delivery management for distributors",
    "longDescription": "NodeRoute is a full-featured delivery and inventory management platform built for seafood, liquor, wine, beer, and broadline food distributors."
  }
}
