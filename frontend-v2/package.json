{
  "name": "noderoute-frontend-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run --reporter=verbose --reporter=hanging-process --pool=forks --no-file-parallelism --teardownTimeout=10000",
    "test:debug-open-handles": "vitest run --reporter=verbose --reporter=hanging-process --detectAsyncLeaks --pool=forks --no-file-parallelism --teardownTimeout=10000",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen http://localhost:5173",
    "test:e2e:report": "playwright show-report",
    "test:smoke": "playwright test --config=playwright.local.config.ts",
    "test:smoke:ui": "playwright test --config=playwright.local.config.ts --ui"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^10.51.0",
    "@tanstack/react-query": "^5.100.9",
    "@tauri-apps/api": "^2.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.59.1",
    "@sentry/vite-plugin": "^5.2.1",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "vitest": {
      "vite": "^6.0.0"
    }
  }
}
