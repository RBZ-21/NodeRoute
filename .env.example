# Server runtime: deployment mode. Use production in hosted environments.
NODE_ENV=development
# Server runtime: Express HTTP port.
PORT=3001
# Server runtime: public base URL used for invite links and payment redirects.
BASE_URL=http://localhost:3001
# Server runtime: maximum JSON body size accepted by Express.
JSON_BODY_LIMIT=1mb
# Server runtime: max rows returned by the orders list endpoint.
ORDERS_LIST_MAX_ROWS=
# Server runtime: max rows returned by the invoices list endpoint.
INVOICES_LIST_MAX_ROWS=
# Server runtime: timezone used by scheduled jobs and date formatting.
TZ=America/New_York
# Server runtime: pino log verbosity.
LOG_LEVEL=info

# Supabase: project REST URL.
SUPABASE_URL=https://your-project.supabase.co
# Supabase: service role key for backend-only database access. Never expose this in clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase: legacy backend service key alias. Prefer SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth: access-token signing secret. Use a long random value; required in production.
JWT_SECRET=change-me-to-a-long-random-string
# Auth: session/CSRF signing secret. Use a separate long random value when possible.
SESSION_SECRET=change-me-to-a-long-random-string
# Auth: optional CSRF-specific secret. Falls back to SESSION_SECRET when empty.
CSRF_SECRET=
# Auth: customer portal token signing secret. Use a different long random value.
PORTAL_JWT_SECRET=change-me-to-a-different-long-random-string
# Auth: bootstrap admin email used by seed/admin scripts.
ADMIN_EMAIL=admin@yourcompany.com
# Auth: bootstrap admin password. REQUIRED in production: minimum 12 characters
# with uppercase, lowercase, a digit, and a special character. The server
# refuses to start in production when this is missing, default, or weak.
ADMIN_PASSWORD=ChangeMe@123
# Auth: superadmin email gate for platform-only routes.
SUPERADMIN_EMAIL=admin@yourcompany.com
# Auth: allow self-serve signup when true (off by default).
ALLOW_PUBLIC_SIGNUP=false

# Email: provider selection. auto tries Resend first, then SMTP.
EMAIL_PROVIDER=auto
# Email: Resend API key for invite and portal email delivery.
RESEND_API_KEY=
# Email: SMTP host for invite and portal email delivery.
SMTP_HOST=
# Email: SMTP port.
SMTP_PORT=587
# Email: SMTP username.
SMTP_USER=
# Email: SMTP password.
SMTP_PASS=
# Email: from address used for operational email and portal messages.
EMAIL_FROM=no-reply@yourcompany.com
# Email: timeout in milliseconds for outbound send attempts.
EMAIL_SEND_TIMEOUT_MS=10000
# Email: set false only when local SMTP uses a self-signed TLS certificate.
SMTP_TLS_REJECT_UNAUTHORIZED=true

# AI: OpenAI API key for AI-assisted routes and fallbacks.
OPENAI_API_KEY=
# AI: Anthropic API key if Anthropic-backed features are enabled.
ANTHROPIC_API_KEY=
# AI: OpenAI text model override for chat, scoring, and recommendations.
OPENAI_MODEL=gpt-4o-mini
# AI: OpenAI vision model override for image/PDF scan flows.
OPENAI_VISION_MODEL=gpt-4o-mini

# Maps: backend Google Maps API key.
GOOGLE_MAPS_KEY=
# Maps: browser-exposed Google Maps API key for Vite builds.
# Restrict this key in Google Cloud Console with HTTP referrers for the
# dashboard and public tracking domains before using it in production.
VITE_GOOGLE_MAPS_KEY=
# Maps: legacy browser Google Maps key alias. Prefer VITE_GOOGLE_MAPS_KEY.
VITE_MAP_API_KEY=
# Maps: backend key alias used by route/geo services. Prefer GOOGLE_MAPS_KEY.
GOOGLE_MAPS_API_KEY=
# Maps: browser key alias checked before VITE_GOOGLE_MAPS_KEY/VITE_MAP_API_KEY.
VITE_GOOGLE_MAPS_PUBLIC_KEY=

# CORS: comma-separated allowed browser origins. Do not use wildcards with credentials.
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
# CORS: legacy single-origin alias. Prefer CORS_ORIGINS.
CORS_ORIGIN=
# Canonical public host (no scheme). www.<host> requests 301-redirect to it.
# Optional: derived from BASE_URL's hostname when unset.
CANONICAL_HOST=
# Security: comma-separated hosts allowed for remote image fetching (AI scans).
ALLOWED_IMAGE_HOSTS=

# Payments: enables customer portal payment flows when true.
PORTAL_PAYMENT_ENABLED=false
# Payments: provider selection for portal payments: manual, stripe, or stub.
PORTAL_PAYMENT_PROVIDER=manual
# Payments: Stripe test keys for backend Checkout preview. Use sk_test_... only until launch.
STRIPE_SECRET_KEY=
# Payments: Stripe test publishable key returned to portal clients. Use pk_test_... only until launch.
STRIPE_PUBLISHABLE_KEY=
# Payments: keep false for preview/test. Production launch requires an intentional live-mode review.
STRIPE_ALLOW_LIVE_MODE=false
# NodeRoute SaaS billing: recurring test Price ID for distributors paying for NodeRoute.
NODEROUTE_STRIPE_PRICE_ID=
# NodeRoute SaaS billing: label shown in Settings; Stripe remains the source of truth.
NODEROUTE_BILLING_PRICE_LABEL=Configured in Stripe
# NodeRoute SaaS billing: product label shown in Settings.
NODEROUTE_BILLING_PRODUCT_NAME=NodeRoute Platform Subscription
# NodeRoute SaaS billing: support contact shown for billing setup issues.
NODEROUTE_BILLING_SUPPORT_EMAIL=billing@yourcompany.com
# Payments: Stripe webhook signing secret.
STRIPE_WEBHOOK_SECRET=
# Payments: allowed Stripe webhook timestamp tolerance in seconds.
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
# NodeRoute SaaS billing: legacy alias for NODEROUTE_STRIPE_PRICE_ID.
STRIPE_NODEROUTE_PRICE_ID=
# Payments: ISO currency used for customer portal payment intents.
PORTAL_PAYMENT_CURRENCY=usd
# Payments: support contact shown when portal payments are unavailable.
PORTAL_PAYMENT_SUPPORT_EMAIL=support@yourcompany.com
# Payments: stub checkout redirect URL used by non-Stripe payment mode.
PORTAL_PAYMENT_STUB_CHECKOUT_URL=
# Portal auth: one-time code lifetime in milliseconds.
PORTAL_CODE_TTL_MS=600000
# Portal auth: resend cooldown in milliseconds for portal login codes.
PORTAL_RESEND_COOLDOWN_MS=60000
# Portal auth: maximum verification attempts per challenge.
PORTAL_MAX_VERIFY_ATTEMPTS=5
# Portal auth: number of portal auth attempts allowed per window.
PORTAL_AUTH_RATE_LIMIT=5
# Portal auth: rate-limit window in milliseconds.
PORTAL_AUTH_RATE_WINDOW_MS=900000
# Portal auth: comma-separated emails allowed to preview portal auth flows in non-production.
PORTAL_PREVIEW_EMAILS=

# Sentry: backend DSN for Express/server error reporting.
SENTRY_DSN=
# Sentry: frontend DSN exposed to the Vite dashboard build.
VITE_SENTRY_DSN=

# Tenant defaults: fallback company id for local/demo data only.
DEFAULT_COMPANY_ID=
# Tenant defaults: fallback company name for local/demo data only.
DEFAULT_COMPANY_NAME=
# Tenant defaults: fallback location id for local/demo data only.
DEFAULT_LOCATION_ID=
# Tenant defaults: fallback location name for local/demo data only.
DEFAULT_LOCATION_NAME=

# Printing: enables the async printer queue when true.
PRINTER_QUEUE_ENABLED=false
# Printing: printer service endpoint for order print jobs.
PRINTER_SERVICE_URL=

# SMS: Twilio account SID for daily fish blast messages.
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
# SMS: Twilio auth token for daily fish blast messages.
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
# SMS: Twilio sender phone number in E.164 format.
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# SMS: company display name used in daily blast copy.
COMPANY_NAME=Your Company Name
# SMS: cron schedule for daily blast jobs in America/New_York.
DAILY_BLAST_CRON=30 6 * * 1-6
# SMS: log instead of sending when true (safe for local/dev).
SMS_DRY_RUN=false
# SMS: outbound message cap per customer per hour.
SMS_RATE_LIMIT_PER_HOUR=6
# Delivery notifications: how many stops ahead triggers the "almost there" SMS.
DELIVERY_NOTIFY_STOPS_AWAY=3
# Scheduler: cron schedule for reorder usage snapshots.
REORDER_USAGE_CRON=0 3 * * *
# Scheduler: cron schedule for reorder checks.
REORDER_CHECK_CRON=15 3 * * *
# Scheduler: cron schedule for reorder digest emails.
REORDER_DIGEST_CRON=30 3 * * *
# Scheduler: cron schedule for credit checks.
CREDIT_CHECK_CRON=0 4 * * *
# AR: monthly finance-charge rate as a decimal (0.015 = 1.5%).
AR_FINANCE_CHARGE_RATE=0.015
# AR: legacy fallback for AR_FINANCE_CHARGE_RATE.
FINANCE_CHARGE_RATE=
# Scheduler: cron schedule for AR aging digest emails.
AR_AGING_DIGEST_CRON=30 4 * * *
# Scheduler: cron schedule for AI insights generation.
AI_INSIGHTS_CRON=0 */6 * * *
# Scheduler: cron schedule for report alert checks.
ALERT_CHECKER_CRON=*/15 * * * *
# Scheduler: cron schedule for the report scheduler loop.
REPORT_SCHEDULER_CRON=*/5 * * * *
# Scheduler: cron schedule for recurring order generation.
RECURRING_ORDERS_CRON=0 20 * * *
# Scheduler: cron schedule for vendor cost/price refresh.
COST_PRICE_UPDATE_CRON=*/15 * * * *
# Alerts: comma-separated recipients for report/scheduler alerts.
REPORT_ALERT_EMAILS=
# Alerts: legacy fallback recipients when REPORT_ALERT_EMAILS is empty.
ALERT_EMAILS=

# Local/offline mode: optional backup path for the demo Supabase adapter.
NODEROUTE_BACKUP_PATH=
# Local/offline mode: force demo-mode storage even when Supabase env vars exist.
NODEROUTE_FORCE_DEMO_MODE=false
# Tests: allow integration tests to use live Supabase credentials when explicitly true.
NODEROUTE_ALLOW_LIVE_SUPABASE_TESTS=false
# Tests: name of the SQL RPC used by the live multi-tenant penetration test.
SUPABASE_SQL_RPC_NAME=
# Tests/CI: set to true in continuous integration environments.
CI=false

# Frontend: API base URL override for dashboard/driver apps when not served by Express.
VITE_API_BASE_URL=
# Frontend: legacy API base URL alias used by the driver app. Prefer VITE_API_BASE_URL.
VITE_API_URL=
# Frontend: application version label attached to Sentry releases/events.
VITE_APP_VERSION=local
# Frontend: optional Statuspage embed script URL.
VITE_STATUSPAGE_EMBED_SCRIPT_URL=
# Frontend: Vite built-in development flag; normally provided by Vite, listed for env audit completeness.
DEV=false
# Frontend: Vite built-in mode name; normally provided by Vite, listed for env audit completeness.
MODE=development

# Screenshot tooling: base URL used by capture-v2-screenshots.mjs.
CAPTURE_BASE_URL=http://localhost:3001
# Screenshot tooling: login email used by capture-v2-screenshots.mjs (required; no fallback).
CAPTURE_EMAIL=admin@yourcompany.com
# Screenshot tooling: login password used by capture-v2-screenshots.mjs (required; no fallback).
CAPTURE_PASSWORD=ChangeMe@123

# ── Supabase CLI (db push / migration list) ───────────────────────────────────
# Project ref from the Supabase dashboard (Settings > General).
SUPABASE_PROJECT_REF=
# Database password from the Supabase dashboard (Settings > Database).
SUPABASE_DB_PASSWORD=
# Optional transaction pooler host override. When unset, scripts/supabase-db-url.mjs uses the direct db.<ref>.supabase.co host.
SUPABASE_POOLER_HOST=

# ── Bland.ai phone order integration ─────────────────────────────────────────
# Shared webhook secret. Send it as the Authorization header (raw value or
# "Bearer <secret>") on the webhook registered in the Bland dashboard — never
# as a query parameter, which would leak it into access logs. Orders created
# with this shared secret are assigned to DEFAULT_COMPANY_ID.
BLAND_WEBHOOK_SECRET=
# Optional per-company webhook secrets as a JSON map of secret -> company id,
# e.g. {"long-random-secret-1":"<company-uuid-1>"}. Lets each tenant's Bland
# agent authenticate with its own credential so phone orders land in the
# right company.
BLAND_COMPANY_SECRETS=
# API key for the public read-only inventory endpoint called by Bland agents
BLAND_INVENTORY_KEY=
# Company assigned to shared-secret Bland phone orders. Falls back to DEFAULT_COMPANY_ID.
BLAND_COMPANY_ID=
# Location assigned to Bland phone orders. Falls back to DEFAULT_LOCATION_ID.
BLAND_DEFAULT_LOCATION_ID=
# E.164 staff phone number that receives SMS alerts for new phone orders
STAFF_PHONE=
