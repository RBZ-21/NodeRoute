# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BASE_URL=http://localhost:3001
JSON_BODY_LIMIT=1mb

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SERVICE_KEY=your-service-role-key # legacy alias; prefer SUPABASE_SERVICE_ROLE_KEY

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-a-long-random-string
# CSRF_SECRET can be used instead of SESSION_SECRET if this deployment separates CSRF signing.
CSRF_SECRET=
PORTAL_JWT_SECRET=change-me-to-a-different-long-random-string
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe@123

# ── Email ─────────────────────────────────────────────────────────────────────
# Use Resend OR SMTP (or both — auto will prefer Resend)
EMAIL_PROVIDER=auto
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Maps ──────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_KEY=
VITE_GOOGLE_MAPS_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
PORTAL_PAYMENT_ENABLED=false
PORTAL_PAYMENT_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ── SMS / Daily Fish Blast (Twilio) ───────────────────────────────────────────
# Sign up at https://twilio.com — a trial account works for testing
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number in E.164 format

# Name shown at the top of the daily SMS (e.g. "Harbor Fresh Seafood")
COMPANY_NAME=Your Company Name

# Cron schedule for the daily fish blast (default: 6:30 AM Mon–Sat)
# Uses America/New_York timezone. Change if needed.
DAILY_BLAST_CRON=30 6 * * 1-6

# ── Bland.ai phone order integration ─────────────────────────────────────────
# Shared secret appended as ?secret= to the webhook URL registered in Bland dashboard
BLAND_WEBHOOK_SECRET=
# API key for the public read-only inventory endpoint called by Bland agents
BLAND_INVENTORY_KEY=
# E.164 staff phone number that receives SMS alerts for new phone orders
STAFF_PHONE=
# TWILIO_NUMBER is an alias for TWILIO_FROM_NUMBER — set either one
TWILIO_NUMBER=
